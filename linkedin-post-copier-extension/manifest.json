{
  "manifest_version": 3,
  "name": "LinkedIn Post Copier (Clipboard)",
  "version": "0.1.0",
  "description": "Dodaje przycisk kopiowania treści wpisu z LinkedIn do schowka.",
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}

